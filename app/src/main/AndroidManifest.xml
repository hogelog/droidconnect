<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:name=".PocketSshApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketSecureShell">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- pss://open?window=<tmux_window> deeplink. Switches the active
                 tmux window after the SSH session connects, using saved
                 credentials. The tmux session is the one this app already
                 attaches to (`pocketssh`). -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pss" android:host="open" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.TerminalActivity"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation" />

        <activity
            android:name=".ui.ShortcutsSettingsActivity"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.EditContextGroupActivity"
            android:parentActivityName=".ui.ShortcutsSettingsActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.HostKeysSettingsActivity"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.LearningSettingsActivity"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.LearningContextActivity"
            android:parentActivityName=".ui.LearningSettingsActivity" />

        <activity
            android:name=".ui.LicensesActivity"
            android:parentActivityName=".MainActivity" />

        <!-- Diagnostic screens are gated behind a hidden menu (seven taps on the
             version label). intent-filter is intentionally absent so exported
             defaults to false and no other app can launch them. -->
        <activity
            android:name=".debug.DiagDumpActivity"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".debug.LogcatActivity"
            android:parentActivityName=".MainActivity" />

        <service
            android:name=".ssh.SshConnectionService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Maintain interactive SSH session while the app is in the background" />
        </service>

    </application>

</manifest>
