<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/terminal_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <org.hogel.droidconnect.ui.ImeProxyView
                android:id="@+id/ime_proxy"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.termux.view.TerminalView
                android:id="@+id/terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <org.hogel.droidconnect.ui.PreeditOverlayView
                android:id="@+id/preedit_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <HorizontalScrollView
            android:id="@+id/tmux_key_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/tmux_key_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp" />

        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/context_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:orientation="horizontal">

            <HorizontalScrollView
                android:id="@+id/context_key_scroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/context_key_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp" />

            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/context_right_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp" />

        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/aux_key_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/aux_key_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp" />

        </HorizontalScrollView>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_disconnect"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:background="@drawable/bg_disconnect_overlay"
        android:contentDescription="@string/disconnect"
        android:padding="8dp"
        android:src="@drawable/ic_close" />

</FrameLayout>
