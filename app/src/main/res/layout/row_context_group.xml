<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardElevation="0dp"
    app:contentPadding="8dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/row_group_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:minHeight="40dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/text_group_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_contexts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:text="@string/shortcuts_edit_contexts"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_group_up"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/shortcuts_move_up"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/shortcuts_glyph_up"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_group_down"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/shortcuts_move_down"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/shortcuts_glyph_down"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_group"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/shortcuts_delete"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/shortcuts_glyph_delete"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/list_group_shortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_group_shortcut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/shortcuts_add_button"
            style="@style/Widget.Material3.Button.TextButton" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
